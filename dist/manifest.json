{
  "manifest_version": 3,
  "name": "Flownote",
  "version": "1.0",
  "description": "A modern dark-themed task manager and notes sidepanel with Google Tasks sync.",
  "permissions": [
    "sidePanel",
    "storage",
    "identity",
    "alarms"
  ],
  "oauth2": {
    "client_id": "1046339328650-50liuojlu4agkscq3gvh188mbn8m2m17.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/tasks"
    ]
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": "Open Flownote",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "commands": {
    "_execute_action": {
      "description": "Open Flownote"
    },
    "quick_capture": {
      "description": "Quick Capture"
    }
  }
}
