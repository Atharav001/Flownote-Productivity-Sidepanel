{
  "manifest_version": 3,
  "name": "flownote",
  "version": "1.0",
  "description": "A modern dark-themed sidebar miniapp.",
  "permissions": [
    "sidePanel",
    "storage"
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Flownote",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "side_panel": {
    "default_path": "index.html"
  }
}
